# Максим/WEBVEB Bot API
MAX_API_TOKEN="your-max-api-token-here"

# PostgreSQL Database (используется в dev-env)
DATABASE_URL="postgresql://meteomax:meteomax@localhost:5432/meteomax"

# Webhook Server
WEBHOOK_BIND="localhost"
WEBHOOK_PORT=8005
WEBHOOK_URL="https://your-domain.com/webhook"

# Meteo API
METEO_API_URL="https://angara.net/meteo/api"
METEO_API_AUTH="Bearer your-meteo-auth-token"
METEO_API_TIMEOUT=5000

# Metrics Server
METRICS_BIND="localhost"
METRICS_PORT=7937

# Application
TIMEZONE="Asia/Irkutsk"
